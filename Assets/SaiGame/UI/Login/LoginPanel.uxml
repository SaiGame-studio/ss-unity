<ui:UXML xmlns:ui="UnityEngine.UIElements"
         xmlns:uie="UnityEditor.UIElements"
         xsi="http://www.w3.org/2001/XMLSchema-instance"
         noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd"
         editor-extension-mode="False">

    <Style src="LoginPanel.uss" />

    <!-- Full-screen root -->
    <ui:VisualElement name="LoginRoot" class="panel-root">

        <!-- Card container -->
        <ui:VisualElement name="LoginCard" class="card">

            <!-- Title -->
            <ui:Label name="TitleLabel" text="Login" class="panel-title" />

            <!-- Username -->
            <ui:Label text="Username or Email" class="field-label" />
            <ui:TextField name="UsernameField"
                          placeholder-text="Enter username or email"
                          class="input-field" />

            <!-- Password -->
            <ui:Label text="Password" class="field-label" />
            <ui:TextField name="PasswordField"
                          placeholder-text="Enter password"
                          password="true"
                          class="input-field" />

            <!-- Divider -->
            <ui:VisualElement class="divider" />

            <!-- Login button -->
            <ui:Button name="LoginButton" text="Log In" class="btn-primary" />

            <!-- Feedback message -->
            <ui:Label name="MessageLabel" text="" class="feedback" />

        </ui:VisualElement>
    </ui:VisualElement>

</ui:UXML>
